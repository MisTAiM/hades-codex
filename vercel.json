{
  "version": 2,
  "name": "hades-codex",
  "buildCommand": "",
  "outputDirectory": ".",
  "routes": [
    { "src": "/api/boons", "dest": "/api/boons.js" },
    { "src": "/api/weapons", "dest": "/api/weapons.js" },
    { "src": "/api/status", "dest": "/api/status.js" },
    { "src": "/(.*)", "dest": "/$1" }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Cache-Control", "value": "s-maxage=3600" }
      ]
    }
  ]
}
